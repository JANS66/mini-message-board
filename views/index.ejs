<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1><%= title %></h1>
            <a href="/new" class="btn">+ New Message</a>
        </header>

        <main class="message-list">
            <% messages.forEach((message, index) => { %>
                <div class="message-card">
                    <div class="message-header">
                        <span class="user-name"><%= message.username %></span>
                        <span class="timestamp"><%= message.added.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                    </div>
                    <p class="message-text"><%= message.message_text %></p>

                    <div style="margin-top: 1rem; text-align: right;">
                        <a href="/message/<%= message.id %>" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.25rem 0.75rem;">Open +</a>
                    </div>
                </div>
            <% }) %>
        </main>
    </div>
</body>
</html>